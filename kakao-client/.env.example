# 카카오 봇 전용 계정
KAKAO_EMAIL=bot@example.com
KAKAO_PASSWORD=your_password_here

# 기기 등록 패스코드 (최초 1회만 필요)
# 첫 실행 시 DEVICE_NOT_REGISTERED 에러가 나면 이메일로 패스코드 발송됨
# 아래에 입력 후 재실행 → 등록 완료되면 이 줄 삭제
# KAKAO_PASSCODE=123456

# yangobot API 주소 (k8s 내부: http://yangobot, 로컬: http://localhost:8080)
YANGOBOT_API_URL=http://localhost:8080

# 관리자 카카오 userId (쉼표 구분, .방추가 명령어 사용 가능)
# userId는 봇 실행 후 로그에서 확인 가능: [bot] senderId=123456789
ADMIN_USER_IDS=123456789,987654321

# 기기 이름 (카카오 로그인 기록에 표시됨)
DEVICE_NAME=yangobot

# 크리덴셜 저장 경로 (PVC 마운트 경로와 맞춰야 함)
CREDENTIAL_PATH=/data/credential.json
